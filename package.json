{
  "name": "cbideal-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/vercel-root-build.mjs",
    "build:all": "npm run build --workspace @cbideal/web && npm run build --workspace @cbideal/app",
    "build:web": "npm run build --workspace @cbideal/web",
    "build:app": "npm run build --workspace @cbideal/app",
    "dev:web": "npm run dev --workspace @cbideal/web",
    "dev:app": "npm run dev --workspace @cbideal/app"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
